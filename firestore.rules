rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['admin@careercraft.ai', 'hitarth0236@gmail.com']
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Promo Codes - Allow public LOOKUP (get) for verification
    match /promoCodes/{promoId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Collection Group rule for Team Members (needed for signup invitation check)
    match /{path=**}/members/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public Resume View
    match /{path=**}/resumeVersions/{versionId} {
      allow read: if resource.data.isPublic == true;
    }

    // User data and subcollections
    match /users/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
      
      match /{allPaths=**} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }
    
    // Global Settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /supportRequests/{requestId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin();

      match /{allPaths=**} {
        allow read, write: if isAdmin() || isOwner(get(/databases/$(database)/documents/supportRequests/$(requestId)).data.userId);
      }
    }
  }
}