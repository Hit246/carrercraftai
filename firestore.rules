rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['admin@careercraft.ai', 'hitarth0236@gmail.com']
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User data and subcollections
    match /users/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
      
      match /{allPaths=**} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }
    
    // Global Settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Promo Codes
    match /promoCodes/{promoId} {
      // Allow anyone to verify a specific code (Document ID)
      // This is safe as it doesn't allow 'list' (browsing all codes)
      allow get: if true;
      // Only admins can see all codes or manage them
      allow list, write: if isAdmin();
    }

    match /supportRequests/{requestId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin();

      match /{allPaths=**} {
        allow read, write: if isAdmin() || isOwner(get(/databases/$(database)/documents/supportRequests/$(requestId)).data.userId);
      }
    }
  }
}